# Azure Web App Environment Variables for Thumbor Container
# Copy these to your Azure Web App Configuration -> Application Settings.
#
# This file mirrors the Thumbor application settings currently configured on
# the App Service. Azure-platform settings (Application Insights,
# Docker registry credentials, diagnostic extensions, the build stamp) are
# managed in the portal / by the Containers workflow and are intentionally
# omitted here. Secret values are blanked — fill them in from Key Vault / portal.


VERSION=0.0.0
PORT=0000




# Security Settings
SECURITY_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_KEY_IF_USED
ALLOW_UNSAFE_URL=True

# Thumbor Process Configuration
THUMBOR_NUM_PROCESSES=16

# CORS Configuration
CORS_ALLOW_ORIGIN=*

# Image Format Settings
AUTO_WEBP=True
AUTO_PNG_TO_JPG=False
WEBP_QUALITY=80
QUALITY=80

# HTTP Loader Settings
HTTP_LOADER_FORWARD_USER_AGENT=True
HTTP_LOADER_TIMEOUT=60

# Azure Blob Storage Configuration
# Option 1: Connection String (recommended for production)
AZURE_STORAGE_CONNECTION_STRING=

# Option 2: Account Name and Key
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=

# Option 3: SAS Token (if not using account key) - secret, fill in from portal/Key Vault
AZURE_STORAGE_SAS_TOKEN=

# Option 4: Managed Identity (recommended for Azure-hosted environments)
AZURE_USE_MANAGED_IDENTITY=False

# Default container for blob storage
AZURE_STORAGE_DEFAULT_CONTAINER=

# Known path prefixes that should use default container
# These are folder names that are treated as paths rather than container names
# Comma-separated list - e.g., if a URL is "perm/rue/file.jpg" and "perm" is in this list,
# it will use the default container with path "perm/rue/file.jpg"
# instead of treating "perm" as the container name
AZURE_KNOWN_PATH_PREFIXES=perm,temp,cache,uploads,files,documents,images

# Cache Configuration (Nginx proxy cache)
THUMBOR_PROXY_CACHE_SIZE=10g
THUMBOR_PROXY_CACHE_MEMORY_SIZE=8192m
THUMBOR_PROXY_CACHE_INACTIVE=256m
THUMBOR_PROXY_CACHE_DURATION=1m

# Storage Settings
STORAGE_EXPIRATION_SECONDS=2592000
RESULT_STORAGE_EXPIRATION_SECONDS=0

# Upload Settings
UPLOAD_MAX_SIZE=104857600
UPLOAD_ENABLED=True
UPLOAD_DELETE_ALLOWED=False

# Image Processing Limits
MAX_WIDTH=3000
MAX_HEIGHT=3000

# Performance Settings
ENGINE_THREADPOOL_SIZE=16

# Error Tracking (Optional)
SENTRY_DSN_URL=

# Azure Specific Settings
ENABLE_SSH=false

# Allowed Sources Pattern
# Note: In Azure Web App, set this as a single line string
ALLOWED_SOURCES=['.+\.example\.com']

# Host Mappings (Optional - handle via DNS or Azure Private Endpoints instead)
# These were previously handled by docker extra_hosts
# Consider using Azure Private Endpoints or DNS configuration for internal routing
# HOSTS_ENTRIES="11.22.33.44 myhost.example.com" # Comma-separated list of "IP_ADDRESS HOSTNAME"

# Redis Settings (Internal - not configurable as Redis runs inside container)
# REDIS_SERVER_HOST=localhost
# REDIS_SERVER_PORT=6379
# REDIS_SERVER_DB=0

# Logging Level
LOG_LEVEL=DEBUG
ENABLE_FILE_LOGGING=false

# Feature Flags
PRESERVE_EXIF_INFO=False
RESPECT_ORIENTATION=True
PROGRESSIVE_JPEG=True
ENABLE_ETAGS=True
SEND_IF_MODIFIED_LAST_MODIFIED_HEADERS=True

# Detection Settings
USE_FACE_DETECTION=True
USE_FEATURE_DETECTION=True
USE_QUEUED_DETECTOR=True

# Optimizer Settings
JPEGTRAN_PROGRESSIVE=True
OPTIPNG_LEVEL=5
AUTO_PNG_TO_JPG_ALPHA=255

# GIF Settings
USE_GIFSICLE_ENGINE=True
FFMPEG_GIF_AUTO_H264=True

# Azure Web App Settings Notes:
# 1. PORT environment variable is automatically set by Azure
# 2. Use Azure Storage Mount for persistent cache if needed
# 3. Configure custom domain and SSL in Azure Portal
# 4. Use Azure Application Insights for monitoring
# 5. Set up Azure CDN in front of Web App for better performance
# 6. Configure autoscaling rules based on your traffic patterns
# 7. Use deployment slots for zero-downtime deployments

# Azure Blob Storage Integration Notes:
# - The custom Azure Blob loader handles SAS tokens properly
# - For production, use either Connection String or Managed Identity
# - Managed Identity is recommended when running in Azure (no keys to manage)
# - Connection String format: DefaultEndpointsProtocol=https;AccountName=xxx;AccountKey=xxx;EndpointSuffix=core.windows.net
# - If using SAS token, ensure it has appropriate permissions (read, list)
# - The loader will fall back to HTTP for non-Azure URLs automatically
